{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "maxDuration": 60
      }
    },
    {
      "src": "web/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/health", "dest": "/api/index.py" },
    { "src": "/share/(.*)", "dest": "/api/index.py" },
    { "src": "/s/(.*)", "dest": "/api/index.py" },
    { "src": "/sitemap\\.xml", "dest": "/api/index.py" },
    { "src": "/robots\\.txt", "dest": "/api/index.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/web/$1" }
  ],
  "crons": [
    {
      "path": "/api/signals/refresh",
      "schedule": "0 14 * * 1-5"
    }
  ]
}
