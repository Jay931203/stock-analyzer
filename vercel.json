{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "maxDuration": 60
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/health", "dest": "/api/index.py" },
    { "src": "/share/(.*)", "dest": "/api/index.py" },
    { "src": "/s/(.*)", "dest": "/api/index.py" },
    { "src": "/sitemap\\.xml", "dest": "/api/index.py" },
    { "src": "/robots\\.txt", "dest": "/api/index.py" }
  ]
}
