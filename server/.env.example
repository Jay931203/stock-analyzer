# Supabase (required for signal caching)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# Vercel Cron authentication (optional, recommended for production)
CRON_SECRET=your-random-secret

# CORS origins (comma-separated, optional - defaults to localhost)
# CORS_ORIGINS=https://your-app.vercel.app,https://custom-domain.com
